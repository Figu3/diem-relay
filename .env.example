# ── Relay ─────────────────────────────────────────────────────

# Venice API
VENICE_API_KEY=your_venice_api_key_here

# Server
PORT=3100
HOST=0.0.0.0

# Admin
ADMIN_SECRET=change_this_to_a_random_string

# Pricing (Phase 0: fixed discount)
DISCOUNT_RATE=0.85
PROTOCOL_FEE_BPS=1000

# ── Contracts ─────────────────────────────────────────────────

# Deployer private key (with 0x prefix)
PRIVATE_KEY=

# Sepolia RPC (Alchemy or Infura)
SEPOLIA_RPC_URL=

# Admin address (defaults to deployer if not set)
ADMIN=

# USDC address on target chain (deploy MockUSDC first on testnet)
DEPOSIT_TOKEN=

# Etherscan API key for verification
ETHERSCAN_API_KEY=
