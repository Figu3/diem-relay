# ── Relay ─────────────────────────────────────────────────────

# Venice API
VENICE_API_KEY=your_venice_api_key_here

# Server
PORT=3100
HOST=0.0.0.0

# Admin
ADMIN_SECRET=change_this_to_a_random_string

# Pricing (Phase 0: fixed discount)
DISCOUNT_RATE=0.85
PROTOCOL_FEE_BPS=1000

# ── Contracts ─────────────────────────────────────────────────

# Deployer private key (with 0x prefix)
PRIVATE_KEY=

# Admin address (defaults to deployer if not set)
ADMIN=

# ── Sepolia (testnet) ──

SEPOLIA_RPC_URL=
ETHERSCAN_API_KEY=
# Deploy MockUSDC first on testnet: forge script script/DeployMockUSDC.s.sol ...
# Then set DEPOSIT_TOKEN to the mock address

# ── Base (mainnet) ──

BASE_RPC_URL=https://mainnet.base.org
BASESCAN_API_KEY=
# USDC on Base: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Deploy: forge script script/DeployDIEMVault.s.sol --rpc-url base --broadcast --verify \
#   -e DEPOSIT_TOKEN=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Token address — USDC on target chain
DEPOSIT_TOKEN=

# ── Deposit Watcher ──

# Vault contract address (set after deploying DIEMVault)
VAULT_ADDRESS=
# RPC URL for watcher (use same as deployment chain)
RPC_URL=
# Chain ID (8453 = Base, 1 = Ethereum, 11155111 = Sepolia)
CHAIN_ID=8453

# ── RevenueSplitter Keeper (daily distribute cron) ────────────

# Hot wallet private key, gas-only, funded with ~$5 of Base ETH.
# Generate with: cast wallet new
KEEPER_KEY=

# Splitter address (defaults to live Base mainnet deployment)
SPLITTER_ADDRESS=0xd185138CEA135E60CA6E567BE53DEC81D89Ce7D6

# Skip distribute() if Base base fee exceeds this many gwei (default: 5)
MAX_BASEFEE_GWEI=5

# Set to "1" to preflight-only, no tx sent
DRY_RUN=

# Optional healthchecks.io (or similar) URL for alerting on missed runs
HEALTHCHECK_URL=
